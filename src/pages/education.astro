---
import Layout from "../shared/components/Layout.astro";

import VideoBg from "../shared/components/VideoBg.astro";

import Education from "../education/assets/videos/compressed.mp4";
import Mobile from "../education/assets/videos/mobile.mp4";

import EducationItem from "../education/components/EducationItem.astro";
import "../shared/styles/global.css";

import { Educations } from "../education/constants/education";
---

<Layout>
    <VideoBg
        src={Education}
        mobileSrc={Mobile}
        loopStart={0}
        loopEnd={19}
        overlay={true}
        class="object-center"
    />

    <main class="flex items-center h-full">
        <h1 class="sr-only" id="page-heading">Contacto</h1>
        <section aria-labelledby="page-heading">
            <ul class="space-y-1">
                {Educations.map((item) => <EducationItem item={item} />)}
            </ul>
        </section>
    </main>
</Layout>
