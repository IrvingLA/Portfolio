---
import Layout from "../shared/components/Layout.astro";

import VideoBg from "../shared/components/VideoBg.astro";

import Contact from "../contact/assets/video/compressed.mp4";
import Mobile from "../contact/assets/video/mobile.mp4";

import "../shared/styles/global.css";

import ContactItem from "../contact/components/ContactItem.astro";
import { Socials } from "../contact/constants/socials";
---

<Layout>
    <VideoBg
        src={Contact}
        mobileSrc={Mobile}
        loopStart={0}
        loopEnd={15}
        overlay={true}
        class="object-left sm:object-center"
    />
    <main class="flex items-center h-full">
        <h1 class="sr-only" id="page-heading">Contacto</h1>
        <section aria-labelledby="page-heading">
            <ul class="space-y-1">
                {
                    Socials.map((social) => (
                        <ContactItem social={social} key={social.name} />
                    ))
                }
            </ul>
        </section>
    </main>
    <a
        href="/"
        data-hover-sound
        class="fixed top-4 left-4 z-40 font-anton uppercase text-primary-600
                   hover:text-primary-400 transition-colors text-lg"
    >
        Menú
    </a>
</Layout>
