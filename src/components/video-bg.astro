---
interface Props {
    src: string;
    mobileSrc?: string;
    loopStart?: number;
    loopEnd?: number;
    overlay?: boolean;
    class?: string;
}

const {
    src,
    mobileSrc,
    loopStart = 0,
    loopEnd,
    overlay,
    class: className = "",
} = Astro.props;
---

<div class="fixed inset-0 -z-10">
    <video
        id="bg-video"
        class={`w-full h-full object-cover ${className}`}
        autoplay
        muted
        playsinline
        preload="auto"
        aria-hidden="true"
        data-loop-start={loopStart}
        data-loop-end={loopEnd}
    >
        {mobileSrc && <source src={mobileSrc} media="(max-width: 768px)" />}
        <source src={src} />
    </video>
    {overlay && <div class="absolute inset-0 " />}
</div>

<script>
    (() => {
        const video = document.getElementById("bg-video");
        if (!video) return;

        const start = parseFloat(video.dataset.loopStart ?? "0");
        const end = parseFloat(video.dataset.loopEnd ?? "");

        if (isFinite(end) && end > start) {
            video.addEventListener("timeupdate", () => {
                if (video.currentTime >= end) {
                    video.currentTime = start;
                }
            });

            video.addEventListener("ended", () => {
                video.currentTime = start;
                video.play().catch(() => {});
            });
        }
    })();
</script>
