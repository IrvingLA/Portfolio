<script is:inline>
    document.addEventListener("mouseenter", (e) => {
        const li = e.target?.closest?.("[data-hover-sound]");
        if (!li) return;
        const audio = new Audio("/sounds/select.mp3");
        audio.volume = 0.5;
        audio.currentTime = 0;
        audio.play().catch(() => {});
    }, true);
</script>