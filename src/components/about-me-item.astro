---
import type { Skills } from "../constants/about-me";
import AboutMeText from "../components/about-me-text.astro";
interface Props {
    skill: Skills;
}

const { skill } = Astro.props;
const dialogId = skill.title.toLowerCase().replace(/\s+/g, "-");
---

<li class="relative group w-fit">
    <div
        class="absolute inset-0 pointer-events-none -translate-y-2 translate-x-2
        bg-tertiary-500 opacity-0 group-hover:opacity-100 transition-opacity duration-400"
        style="clip-path: polygon(0 20%, 100% 0, 98% 100%, 0% 100%);"
        aria-hidden="true"
    >
    </div>
    <div
        role="button"
        tabindex="0"
        aria-haspopup="dialog"
        data-dialog-trigger
        data-dialog-id={dialogId}
        class="bg-black text-white font-sora w-fit
                    flex items-center px-4 space-x-2
                    hover:bg-neutral-50 hover:text-black hover:ps-12
                    transition-colors ease-in cursor-pointer relative z-10"
        style="clip-path: polygon(0 0, 100% 0, 98% 100%, 0% 100%);"
    >
        <div class="relative inline-flex pointer-events-none">
            <img
                src={skill.urlImage}
                alt={skill.altImage}
                class="h-12 sm:w-32"
            />
            <div
                class={`absolute inset-0 mix-blend-color ${skill.color}`}
                aria-hidden="true"
            >
            </div>
        </div>
        <h2 class="capitalize skew-x-2 md:text-xl w-28 pointer-events-none">
            {skill.title}
        </h2>
        <span
            class="w-0.5 h-10 bg-primary-500 rotate-30 pointer-events-none"
            aria-hidden="true"
        >
        </span>
        <dl class="-skew-x-12 translate-y-2 pointer-events-none">
            <dt class="capitalize font-jetbrains font-bold inline">lv</dt>
            <dd class="font-jetbrains pt-4 inline">
                <span class="md:text-2xl">{skill.lv}</span>
            </dd>
        </dl>
        <div class="-skew-x-12 group font-jetbrains pointer-events-none">
            <dl>
                <dt
                    class="capitalize text-primary-500 group-hover:text-black inline"
                >
                    hp
                </dt>
                <dd
                    class="capitalize text-primary-500 group-hover:text-black inline"
                >
                    <span class="md:text-2xl">{skill.hp}</span>
                </dd>
            </dl>
            <div
                class="w-full h-2 bg-primary-500
                            group-hover:border-black group-hover:border-b-2 group-hover:border-e-2"
                aria-hidden="true"
            >
            </div>
        </div>
        <div class="-skew-x-12 group font-jetbrains pointer-events-none">
            <dl>
                <dt
                    class="capitalize text-amber-300 group-hover:text-black -skew-x-12 inline"
                >
                    sp
                </dt>
                <dd
                    class="capitalize text-amber-300 group-hover:text-black inline"
                >
                    <span class="md:text-2xl">{skill.sp}</span>
                </dd>
            </dl>
            <div
                class="w-full h-2 bg-amber-300
                group-hover:border-black group-hover:border-b-2 group-hover:border-e-2"
                aria-hidden="true"
            >
            </div>
        </div>
    </div>
</li>

<dialog
    id={dialogId}
    class="dialog-animate inset-0 z-50 m-0 h-dvh w-dvw max-h-dvw max-w-full
               bg-black/20 text-white font-sora relative overflow-hidden"
>
    <div
        class="inset-0 z-0 bg-white border-t-4 border-red-600
        -rotate-8 h-fit w-[120%] py-4 text-black
        -translate-x-10 md:-translate-x-16 lg:-translate-y-12
        grid grid-cols-12"
    >
        <div
            class="w-full h-12 md:h-16 my-2 md:my-4 -skew-x-12 bg-black
        col-start-2 col-span-11"
        >
        </div>
        {
            skill.dialog && (
                <skill.dialog
                    class="font-sora -skew-x-8
                    text-sm md:text-xl row-start-2
                 col-start-2 md:col-start-2 lg:col-start-2
                 col-span-9 sm:col-span-10 md:col-span-9 lg:col-span-4"
                />
            )
        }
        <div
            class="w-full h-8 my-4 -skew-x-12 bg-black
                col-start-2 col-span-11 -translate-x-10 md:-translate-x-20"
        >
        </div>
    </div>
    <div
        class="bg-white/5 backdrop-blur-md border-l border-white/20 absolute right-0 bottom-0 z-10
        h-1/3 sm:h-1/2 lg:h-full
        w-full lg:w-1/2"
        style="clip-path: polygon(32% 0, 100% 0, 100% 100%, 7% 100%, 0 77%);"
    >
        <div class="relative right-0 bottom-0 h-full">
            <img
                src={skill.urlCharacter}
                alt={skill.altImage}
                class="size-full object-cover"
            />
            <div
                class="size-2/5 bg-gray-800 absolute right-0 bottom-0"
                style="clip-path: polygon(100% 0, 0% 100%, 100% 100%);"
            >
            </div>
        </div>
        <div
            class="absolute inset-0 pointer-events-none overflow-hidden"
            aria-hidden="true"
        >
            <div
                class="absolute -inset-x-[50%] inset-y-0 w-[200%] bg-gradient-to-r from-transparent via-white/15 to-transparent -skew-x-12 crystal-shine"
            >
            </div>
        </div>
    </div>
</dialog>

<script>
    document.querySelectorAll("[data-dialog-trigger]").forEach((trigger) => {
        const dialogId = trigger.dataset.dialogId;
        const dialog = document.getElementById(dialogId);
        if (!dialog) return;

        const openDialog = () => dialog.showModal();

        trigger.addEventListener("click", openDialog);

        trigger.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
                e.preventDefault();
                openDialog();
            }
        });

        dialog.addEventListener("click", (e) => {
            if (e.target === dialog) dialog.close();
        });
    });
</script>

