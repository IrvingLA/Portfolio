---
import type { Page } from "./pages.data";

interface Props {
    page: Page;
}

const { page } = Astro.props;
---

<li
    data-hover-sound
    class={`group relative w-fit -skew-12 ${page.extraClasses}`}
>
    <a
        href={page.href}
        class="relative z-20 block px-3 py-1
        group-hover:scale-150 group-hover:translate-x-14"
    >
        <span
            class={`relative z-30 group-hover:text-primary-950
                transition-all duration-300 ${page.textColor}`}
        >
            {page.label}
        </span>
        <span
            class="absolute inset-0 z-40 text-red-500 opacity-0
                    group-hover:opacity-100 transition-all duration-300
                    translate-x-3 translate-y-1"
            style="clip-path: polygon(100% 15%, 95% 95%, 0 56%);"
            aria-hidden="true"
        >
            {page.label}
        </span>
    </a>
    <span
        class="absolute inset-0 z-10 origin-left scale-x-0 bg-white rotate-3
    transition-transform duration-300 ease-out group-hover:scale-190"
        style="clip-path: polygon(95% 2%, 90% 90%, 10% 60%);"></span>
    <span
        class="absolute inset-0 z-0 origin-left scale-x-0 bg-red-500/60 rotate-3
    transition-transform duration-300 ease-out group-hover:scale-190"
        style="clip-path: polygon(100% 0, 95% 95%, 0 60%);"></span>
</li>
